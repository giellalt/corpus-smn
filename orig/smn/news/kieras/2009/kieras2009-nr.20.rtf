\fs28 4. MOONN\'c2\u272? PIL\'c1N V\'c2I PILL\'c2\'8aU\u272??\par
\fs24\par
\lang1078\b0 Suom\'e2kiel\'e2st lii t\'e1v\'e1l\'e2\'9a ett\'e2mvyehi \i menn\'e4 pilalle\i0\f1 . Tom lii liijk\'e1s-uv \'e4lkkee jurg\'e2listi\'f0 nuht\'e1n s\'e4mikiel\'e2n: \i moonn\'e2\'f0 pil\'e1n\i0 . Mut tot ij lah vuov\'e2s, veikk\'e2 tot kale kustoo vigg\'e1 njaah\'e2\'f0 korr\'e2s\'e1vt kiel\'e2n. T\'e1v\'e1l\'e1vth\'e2n i\'e4ttoo, et\i\f0  tot pill\'e2\'9aui, taath\'e2n lii pill\'e2\'9aum\i0  jna.\par
\par
\f1 Suom\'e2kiel\'e2 moonn\'e2\'f0-veerb\'e2n ku\'e1lustum s\'e4\'e4nih l\'e1\'e1-uv t\'e1vj\'e1 vigg\'e2min s\'e4mikiel\'e2n nju\'e1lgu jurg\'e2luss\'e2n, ovd\'e2merkk\'e2n n\'e1vt:\par
\f0\par
\f1 menn\'e4 nukkumaan - moonn\'e2\'f0 u\'e1\'f0\'f0i\'f0, vrd. u\'e1\'f0\'f0\'e1\'f0.\par
menn\'e4 poikki - moonn\'e2\'f0 rasta, vrd. toiju\'f0, potk\'e2ni\'f0\par
menn\'e4 ansaan - moonn\'e2\'f0 kiel\'e2n, vrd. \'e8aa\u331?\u331?\'e2\'f0 kiel\'e2n\par
tikku meni kynnen alle - s\'e4ggi moon\'e2i kooz\'e2 vu\'e1l, vrd. su\'e1\'f0is poostij kooz\'e2 vu\'e1l \par
juomana menee vesikin - juh\'e2mu\'9a\'9a\'e2n mana \'e8\'e4\'e4ci-uv, vrd. juh\'e2mu\'9a\'9a\'e2n tohhee \'e8\'e4\'e4ci-uv\f0\par
meneeh\'e4n se ty\'f6puserona - manah\'e2n tot pargopuserin, vrd. aaneeth\'e2n tot pargopuserin\par
\par
